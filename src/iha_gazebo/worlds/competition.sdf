<?xml version="1.0"?>
<sdf version="1.7">
  <world name="competition">
    <physics name="1ms" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-magnetometer-system" name="gz::sim::systems::Magnetometer"/>
    <plugin filename="gz-sim-air-pressure-system" name="gz::sim::systems::AirPressure"/>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <latitude_deg>-35.363262</latitude_deg>
      <longitude_deg>149.165237</longitude_deg>
      <elevation>584</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.5 -1</direction>
    </light>

    <scene>
      <ambient>0.8 0.8 0.8 1</ambient>
      <background>0.7 0.85 1 1</background>
      <shadows>true</shadows>
    </scene>

    <model name="grass_field">
      <static>true</static>
      <pose>0 0 0.05 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>500 500 0.1</size></box></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>500 500 0.1</size></box></geometry>
          <material>
            <ambient>0.10 0.28 0.09 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
            <pbr><metal><albedo_map>file:///home/inci/iha_ws/src/iha_gazebo/worlds/materials/textures/grass.jpg</albedo_map><roughness>1.0</roughness><metalness>0.0</metalness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <model name="runway">
      <static>true</static>
      <pose>-175 0 0.105 0 0 0</pose>
      <link name="link">
        <collision name="runway_collision">
          <geometry><box><size>110 10 0.01</size></box></geometry>
          <surface>
            <friction><ode><mu>1.2</mu><mu2>1.2</mu2><fdir1>1 0 0</fdir1><slip1>0.0</slip1><slip2>0.0</slip2></ode></friction>
            <contact><ode><soft_cfm>0.0001</soft_cfm><soft_erp>0.2</soft_erp><kp>1000000</kp><kd>1</kd><max_vel>0.2</max_vel><min_depth>0.001</min_depth></ode></contact>
          </surface>
        </collision>
        <visual name="runway_visual">
          <geometry><box><size>110 10 0.01</size></box></geometry>
          <material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.02 0.02 0.02 1</specular></material>
        </visual>
