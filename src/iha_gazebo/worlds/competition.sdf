    <!-- PX4 gz_rc_cessna bu world açıldıktan sonra rc_cessna_0 modelini kendisi spawn eder.
         Bu yüzden world içine ayrıca advanced_plane gömülmedi. -->

    <model name="direk_1">
      <static>true</static>
      <pose>-150 100 25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
